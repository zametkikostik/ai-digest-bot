# ===========================================
# AI Digest Bot - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# -------------------------------------------
# Telegram Bot Configuration
# -------------------------------------------
# Get from @BotFather on Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# -------------------------------------------
# Bot Identity
# -------------------------------------------
BOT_NAME="AI-дайджест"
BOT_TOPIC="Всё об искусственном интеллекте за неделю. Новости, инструменты, лайфхаки"

# -------------------------------------------
# Admin Configuration
# -------------------------------------------
# Your Telegram user ID (get from @userinfobot)
ADMIN_IDS="1271633868"

# -------------------------------------------
# Channels (optional)
# -------------------------------------------
# Channel IDs for auto-posting (start with -100)
CHANNEL_ID="-1001859702206"
INVEST_CHANNEL="-1001644114424"

# -------------------------------------------
# AI Configuration
# -------------------------------------------
# OpenRouter API key for AI features
OPENROUTER_API_KEY=your_openrouter_key_here

# System prompt for AI
SYSTEM_PROMPT="Ты полезный AI-ассистент."

# -------------------------------------------
# RAG Configuration
# -------------------------------------------
# Path to ChromaDB storage
CHROMA_DB_PATH="./chroma_db"

# Embedding model
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
# Max requests per user per minute
RATE_LIMIT_PER_USER=10

# -------------------------------------------
# Logging
# -------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -------------------------------------------
# Cloudflare Workers (for cloud deployment)
# -------------------------------------------
# These are set in Cloudflare Dashboard, not in .env
# BOT_TOKEN - same as above
# ADMIN_IDS - same as above
# CHANNEL_ID - same as above
# OPENROUTER_API_KEY - same as above
